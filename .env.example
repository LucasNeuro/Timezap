# Mistral — https://console.mistral.ai/api-keys/

MISTRAL_API_KEY=

MISTRAL_MODEL_ID=mistral-large-latest



# Servidor (opcional)

# HOST=127.0.0.1

# PORT=8000

# RELOAD=1

# Render Web Service: fixar Python (evitar 3.14.x por defeito). No painel ou .env de CI:
# PYTHON_VERSION=3.11.9
# Start Command no Render NÃO pode ser só "pip install"; ver docs/deploy-render.md

# Opcional Linux/Render — clientes HTTP custom do Mistral (por defeito desligados fora Windows)
# AGNO_CUSTOM_HTTPX=1

# Telemetria Agno (por defeito 0 neste projeto)
# AGNO_TELEMETRY=0

# Onde criar SQLite (Render sem isto usa /tmp/timezap quando RENDER=true)
# TIMEZAP_SQLITE_DIR=

# Windows: SSL nos pedidos ao Mistral (ver app.py)
# AGNO_USE_CERTIFI_CA=0
# AGNO_SSL_TRUSTSTORE=0

