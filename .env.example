# Mistral — https://console.mistral.ai/api-keys/

MISTRAL_API_KEY=

MISTRAL_MODEL_ID=mistral-large-latest



# Servidor (opcional)

# HOST=127.0.0.1

# PORT=8000

# RELOAD=1

# Render Web Service: fixar Python (evitar 3.14.x por defeito). No painel ou .env de CI:
# PYTHON_VERSION=3.11.9

# Windows: SSL nos pedidos ao Mistral (ver app.py)

# AGNO_USE_CERTIFI_CA=0

# AGNO_SSL_TRUSTSTORE=0

